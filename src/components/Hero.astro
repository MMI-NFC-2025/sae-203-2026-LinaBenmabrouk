---
import Logo from "../assets/icons/logo.svg";
import { Image } from "astro:assets";
import DroneBeige from "../assets/icons/dronebeige.svg";
---

<section class="bg-orange px-6 pt-16 pb-8 text-center text-white font-barlow">
  <div class="mx-auto flex max-w-sm flex-col items-center">
    <div class="relative mt-8 flex w-full justify-center">
      <Image
      src={DroneBeige}
      alt=""
      class="absolute left-8 top-1/2 mt-2 h-3 w-auto -translate-y-1/2"
      />
      
      <Image
      src={DroneBeige}
      alt=""
      class="absolute right-8 top-1/3 h-3 w-auto"
      />
      
      <Image
      src={DroneBeige}
      alt=""
      class="absolute right-2 top-2/3 h-3 w-auto"
      />

      <Logo class="h-48 w-48 text-beige" />
    </div>

    <h1 class="mt-6 text-4xl font-bold leading-tight">
      Un festival entre
      <span class="block text-yellow">Ciel et Terre</span>
    </h1>

    <a
  href="/billetterie"
  class="mt-10 mx-auto block w-fit rounded-sm bg-beige px-10 py-3 text-center text-sm font-bold uppercase tracking-wide text-orange"
>
  Accéder à la billetterie
</a>
  </div>
</section>