---
import Logo from "../assets/icons/logo.svg";
import { Image } from "astro:assets";
import DroneBeige from "../assets/icons/dronebeige.svg";
---

<section class="bg-orange px-6 pt-16 pb-8 text-center text-white font-barlow lg:px-10 lg:pt-28 lg:pb-16 lg:text-left">
  <div class="mx-auto flex max-w-sm flex-col items-center lg:max-w-7xl lg:flex-row lg:items-center lg:justify-between lg:gap-16">
    <div class="relative mt-8 flex w-full justify-center lg:mt-0 lg:w-1/2">
      <Image
        src={DroneBeige}
        alt=""
        class="absolute left-8 top-1/2 mt-2 h-3 w-auto -translate-y-1/2 lg:left-20 lg:h-5"
      />
      
      <Image
        src={DroneBeige}
        alt=""
        class="absolute right-8 top-1/3 h-3 w-auto lg:right-20 lg:h-5"
      />
      
      <Image
        src={DroneBeige}
        alt=""
        class="absolute right-2 top-2/3 h-3 w-auto lg:right-8 lg:h-5"
      />

      <Logo class="h-48 w-48 text-beige lg:h-70 lg:w-70" />
    </div>

    <div class="lg:flex lg:w-1/2 lg:flex-col lg:items-start">
      <h1 class="mt-6 text-4xl font-bold leading-tight lg:mt-0 lg:max-w-xl lg:text-6xl">
        Un festival entre
        <span class="block text-yellow">Ciel et Terre</span>
      </h1>

      <a
        href="/billetterie"
        class="mt-10 mx-auto block w-fit rounded-sm bg-beige px-10 py-3 text-center text-sm font-bold uppercase tracking-wide text-orange lg:mx-0 lg:mt-12 lg:px-12 lg:py-4"
      >
        Accéder à la billetterie
      </a>
    </div>
  </div>
</section>