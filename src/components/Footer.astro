---
import LogoFooter from '../assets/icons/logofooter-beige.svg';
---

<footer class="relative bg-orange font-barlow px-6 py-20 text-center text-white lg:px-10 lg:py-24">
  <div class="lg:mx-auto lg:max-w-7xl">
    <div class="lg:flex lg:items-start lg:justify-between lg:gap-12">
      <div class="lg:max-w-sm lg:text-left">
        <p class="mx-auto max-w-md text-xl font-semibold leading-snug lg:mx-0 lg:text-3xl">
          Entre ciel et terre,
          <span class="block text-yellow">
            vivez l’expérience Flying Tap Fest.
          </span>
        </p>
      </div>

      <ul class="mt-10 space-y-2 text-base font-bold lg:mt-0 lg:text-left">
        <li><a href="/">Accueil</a></li>
        <li><a href="/festival">Le festival</a></li>
        <li><a href="/programme">Programme</a></li>
        <li><a href="/artiste">Artistes</a></li>
        <li><a href="/scene">Scènes</a></li>
        <li><a href="/infos">Infos pratiques</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/mentions-legales">Mentions légales</a></li>
      </ul>

      <div class="lg:flex lg:flex-col lg:items-end lg:text-right">
        <div class="mt-10 flex justify-center lg:mt-0 lg:justify-end">
          <a href="/" aria-label="Accueil Flying Tap Fest">
            <LogoFooter class="h-52 w-52 lg:h-64 lg:w-64" />
          </a>
        </div>

        <div class="mt-4 flex justify-center gap-10 text-xs font-semibold tracking-widest uppercase lg:justify-end">
          <a href="#">Instagram</a>
          <a href="#">FaceBook</a>
          <a href="mailto:contact@flyingtapfest.fr">email</a>
        </div>

        <div class="mt-12 space-y-0 text-xs lg:text-right">
          <p class="font-semibold mb-2">contact@flyingtapfest.fr</p>
          <p>Montbéliard, France</p>
          <p>Site du Flying Tap Fest</p>
        </div>

        <p class="mt-6 text-xs">
          © 2026 Flying Tap Fest
        </p>
      </div>
    </div>
  </div>
</footer>