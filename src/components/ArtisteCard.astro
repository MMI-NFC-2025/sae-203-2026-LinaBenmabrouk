---
const artiste = Astro.props.artiste ?? {};
import PbImage from "./PbImage.astro";

const rawDate = artiste.date || "";

const heure = rawDate ? rawDate.slice(11, 16) : "";
const jourNumero = rawDate ? String(parseInt(rawDate.slice(8, 10), 10)) : "";
const moisNumero = rawDate ? rawDate.slice(5, 7) : "";

const moisLabel =
  moisNumero === "01" ? "janvier" :
  moisNumero === "02" ? "février" :
  moisNumero === "03" ? "mars" :
  moisNumero === "04" ? "avril" :
  moisNumero === "05" ? "mai" :
  moisNumero === "06" ? "juin" :
  moisNumero === "07" ? "juillet" :
  moisNumero === "08" ? "août" :
  moisNumero === "09" ? "septembre" :
  moisNumero === "10" ? "octobre" :
  moisNumero === "11" ? "novembre" :
  moisNumero === "12" ? "décembre" :
  "";

const jour = jourNumero && moisLabel ? `${jourNumero} ${moisLabel}` : "";
const lieuNom = artiste.expand?.lieu?.at(0)?.nom || "";
---

<div class="flex justify-center px-5">
  <div class="relative h-96 w-80 overflow-hidden rounded-3xl">
    <PbImage
      record={artiste}
      imageField={artiste.photo}
      class="absolute inset-0 h-full w-full object-cover"
    />

    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/10 to-transparent"></div>

    <div class="absolute inset-x-0 top-4 px-8 text-center text-white">
      <p class="text-base font-bold">
        {heure} - {jour} – {lieuNom}
      </p>

      <h3 class="mt-2 text-xl font-bold leading-tight">
        {artiste.nom}
      </h3>
    </div>

    <div class="absolute inset-x-0 bottom-4 flex justify-center">
      <a
        href={`/artiste/${artiste.id}`}
        class="inline-flex items-center justify-center rounded-lg bg-beige px-5 py-2 text-base font-bold uppercase text-orange"
      >
        En savoir plus
      </a>
    </div>
  </div>
</div>