---
const { member } = Astro.props;
import PbImage from './PbImage.astro';
---

<div class="flex flex-col items-center rounded-2xl border border-orange/20 bg-beige/40 p-6 text-center shadow-sm">

  <div class="h-24 w-24 overflow-hidden rounded-full">
    <PbImage
      record={member}
      imageField={member.photo}
      class="h-full w-full object-cover"
    />
  </div>

  <h3 class="mt-4 text-lg font-bold text-orange text-center">
    {member.prenom} {member.nom}
  </h3>

  <p class="mt-1 text-sm uppercase text-blue text-center">
    {member.role}
  </p>

  <p class="mt-3 max-w-xs text-sm leading-relaxed text-center">
    {member.description}
  </p>

</div>