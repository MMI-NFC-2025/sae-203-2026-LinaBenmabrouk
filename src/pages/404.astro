---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Logo from "../assets/icons/logofooter-orange.svg";
import Vagues from "../assets/icons/vagues.svg";
---

<Layout title="Page introuvable">
  <section class="min-h-screen pb-20 pt-16 text-center">

    <div class="bg-orange pt-6">
      <Image
        src={Vagues}
        alt=""
        class="block w-full"
      />
    </div>

    <h1 class="-mt-px bg-beige text-5xl font-bold text-orange">
      Erreur 404
    </h1>

    <div class="mt-10 flex justify-center">
      <Image
        src={Logo}
        alt="Flying Tap Fest"
        class="h-40 w-auto"
      />
    </div>

    <div class="mx-auto mt-10 max-w-3xl px-6">

      <p class="text-4xl font-bold uppercase text-orange">
        Page introuvable
      </p>

      <p class="mt-6 text-xl leading-relaxed text-blue">
        Oups… cette page semble avoir quitté la scène.
      </p>

      <form id="search404" class="mt-10 flex justify-center">
        <input
          id="searchInput"
          type="text"
          placeholder="Rechercher sur Flying Tap Fest"
          class="w-full max-w-xl rounded-lg border border-orange bg-beige px-6 py-4 text-lg text-blue placeholder-blue outline-none"
        />
      </form>

    </div>

  </section>
</Layout>

<script is:inline>
  const form = document.getElementById("search404");
  const input = document.getElementById("searchInput");

  form.addEventListener("submit", function(e) {
    e.preventDefault();

    const query = input.value.toLowerCase().trim();

    if (query.includes("programme")) {
      window.location.href = "/programme";
    } 
    else if (query.includes("artiste")) {
      window.location.href = "/artistes";
    }
    else if (query.includes("scène") || query.includes("scene")) {
      window.location.href = "/scenes";
    }
    else if (query.includes("info")) {
      window.location.href = "/infos";
    }
    else if (query.includes("contact")) {
      window.location.href = "/contact";
    }
    else {
      window.location.href = "/";
    }
  });
</script>