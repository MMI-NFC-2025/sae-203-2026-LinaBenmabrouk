---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import Logo from "../../assets/icons/logofooter-orange.svg";
import Vagues from "../../assets/icons/vagues.svg";
import PbImage from "../../components/PbImage.astro";
import { getArtisteById, getImageUrl } from "../../../backend/backend.mjs";

const { id } = Astro.params;
const artiste = await getArtisteById(id);

const rawDate = artiste.date || "";

const heure = rawDate ? rawDate.slice(11, 16) : "";
const jourNumero = rawDate ? String(parseInt(rawDate.slice(8, 10), 10)) : "";
const moisNumero = rawDate ? rawDate.slice(5, 7) : "";

const moisLabel =
  moisNumero === "01" ? "janvier" :
  moisNumero === "02" ? "février" :
  moisNumero === "03" ? "mars" :
  moisNumero === "04" ? "avril" :
  moisNumero === "05" ? "mai" :
  moisNumero === "06" ? "juin" :
  moisNumero === "07" ? "juillet" :
  moisNumero === "08" ? "août" :
  moisNumero === "09" ? "septembre" :
  moisNumero === "10" ? "octobre" :
  moisNumero === "11" ? "novembre" :
  moisNumero === "12" ? "décembre" :
  "";

const dateLabel = jourNumero && moisLabel ? `${jourNumero} ${moisLabel}` : "";
const lieuNom = artiste.expand?.lieu?.at(0)?.nom || "";

const galerie = artiste.photos || [];

const galerieUrls = await Promise.all(
  galerie.map(async (photo) => {
    const url = await getImageUrl(artiste, photo);
    return url;
  })
);
---

<Layout title={artiste.nom}>
  <section class="pb-20 pt-16 text-center">
    <div class="bg-orange pt-6">
      <Image
        src={Vagues}
        alt=""
        class="block w-full"
      />
    </div>

    <h1 class="-mt-px bg-beige text-3xl font-bold text-orange">
      {artiste.nom}
    </h1>

    <div class="mt-5 flex items-center justify-center gap-3 text-sm font-bold">
      <a href="/">Accueil</a>
      <span class="text-orange">›</span>
      <a href="/artiste">Artistes</a>
      <span class="text-orange">›</span>
      <span class="text-orange">{artiste.nom}</span>
    </div>

    <div class="mt-5 flex justify-center">
      <Image
        src={Logo}
        alt=""
        class="h-52 w-auto"
      />
    </div>

    <div class="mt-10 px-5">
      <div class="mx-auto max-w-3xl text-center">
        <div class="mt-8 overflow-hidden rounded-3xl">
          <PbImage
            record={artiste}
            imageField={artiste.photo}
            class="h-auto w-full object-cover"
          />
        </div>
        
        <p class="mt-5 text-center">
            {dateLabel} - {heure} - {lieuNom}
        </p>

        <p class="mt-8 text-base text-left leading-relaxed whitespace-pre-line">
          {artiste.description}
        </p>
      </div>
    </div>

    <div class="mt-20 px-5">
      <h2 class="text-3xl font-bold uppercase text-orange">
        Galerie photo
      </h2>

      <div class="mx-auto mt-10 grid max-w-5xl gap-6 md:grid-cols-2">
        {galerieUrls.length > 0 ? (
          galerieUrls.map((url) => (
            <div class="overflow-hidden rounded-3xl">
              <img
                src={url}
                alt={artiste.nom}
                class="h-72 w-full object-cover"
              />
            </div>
          ))
        ) : (
          <p class="md:col-span-2 text-center text-xl text-blue">
            Aucune photo complémentaire pour le moment.
          </p>
        )}
      </div>
    </div>

    <div class="mt-12 text-center">
      <div class="flex justify-center">
        <Image
          src={Logo}
          alt="Flying Tap Fest"
          class="h-auto w-auto"
        />
      </div>

      <p class="mt-6 px-10 text-3xl font-bold uppercase text-orange">
        Tout ce qu'il faut savoir pour venir.
      </p>

      <a
        href="/infos"
        class="mt-6 inline-flex items-center justify-center rounded-lg bg-orange px-8 py-2 text-lg font-bold uppercase text-white"
      >
        Voir les infos
      </a>
    </div>
  </section>
</Layout>