---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import Logo from "../../assets/icons/logofooter-orange.svg";
import Vagues from "../../assets/icons/vagues.svg";
import ArtisteCard from "../../components/ArtisteCard.astro";
import { getArtistes } from "../../../backend/backend.mjs";

const artistes = await getArtistes();

const artistes6Juin = artistes.filter((artiste) => artiste.date?.slice(8, 10) === "06");
const artistes7Juin = artistes.filter((artiste) => artiste.date?.slice(8, 10) === "07");
---

<Layout title="Artistes">
  <section class="pb-20 pt-16 text-center lg:pb-28">
    <div class="bg-orange pt-6 lg:pt-10">
      <Image 
        src={Vagues}
        alt=""
        class="block w-full"
      />
    </div>

    <h1 class="-mt-px bg-beige text-3xl font-bold text-orange lg:text-6xl lg:pb-2">
      Artistes
    </h1>

    <div class="mt-5 flex items-center justify-center gap-3 text-sm font-bold lg:mt-6 lg:gap-4">
      <a href="/">Accueil</a>
      <span class="text-orange">›</span>
      <span class="text-orange">Artistes</span>
    </div>

    <div class="mt-5 flex justify-center lg:mt-8">
      <Image 
        src={Logo}
        alt=""
        class="h-52 w-auto lg:h-64"
      />
    </div>

    <div class="text-center lg:mx-auto lg:max-w-4xl lg:px-10">
      <p class="px-15 text-xl leading-relaxed lg:px-0 lg:text-2xl">
        Découvrez les artistes qui rythmeront le Flying Tap Fest.
      </p>
    </div>

    <div class="mt-16 flex justify-center gap-10 text-3xl font-bold uppercase">
      <button
        id="tab-tout"
        type="button"
        class="tab-btn border-b-4 border-orange pb-2 text-orange"
        data-target="section-tout"
      >
        Tout
      </button>

      <button
        id="tab-6juin"
        type="button"
        class="tab-btn pb-2 text-gray-400"
        data-target="section-6juin"
      >
        6 juin
      </button>

      <button
        id="tab-7juin"
        type="button"
        class="tab-btn pb-2 text-gray-400"
        data-target="section-7juin"
      >
        7 juin
      </button>
    </div>

    <div id="section-tout" class="artist-section mt-16">
      <div class="space-y-12 lg:mx-auto lg:grid lg:max-w-7xl lg:grid-cols-3 lg:gap-10 lg:space-y-0 lg:px-10">
        {artistes.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>
    </div>

    <div id="section-6juin" class="artist-section mt-16 hidden">
      <div class="space-y-12 lg:mx-auto lg:grid lg:max-w-7xl lg:grid-cols-3 lg:gap-10 lg:space-y-0 lg:px-10">
        {artistes6Juin.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>
    </div>

    <div id="section-7juin" class="artist-section mt-16 hidden">
      <div class="space-y-12 lg:mx-auto lg:grid lg:max-w-7xl lg:grid-cols-3 lg:gap-10 lg:space-y-0 lg:px-10">
        {artistes7Juin.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>
    </div>

    <div class="mt-12 text-center lg:mt-20">
      <div class="flex justify-center">
        <Image
          src={Logo}
          alt="Flying Tap Fest"
          class="h-auto w-auto lg:h-56"
        />
      </div>

      <p class="mt-6 px-10 text-3xl font-bold uppercase text-orange lg:mx-auto lg:max-w-3xl">
        Tout ce qu'il faut savoir pour venir.
      </p>

      <a
        href="/infos"
        class="mt-6 inline-flex items-center justify-center rounded-lg bg-orange px-8 py-2 text-lg font-bold uppercase text-white lg:mt-8 lg:px-10 lg:py-3"
      >
        Voir les infos
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
  // @ts-nocheck
  const tabs = document.querySelectorAll(".tab-btn");
  const sections = document.querySelectorAll(".artist-section");

  function activateTab(targetId) {
    sections.forEach((section) => {
      if (section.id === targetId) {
        section.classList.remove("hidden");
      } else {
        section.classList.add("hidden");
      }
    });

    tabs.forEach((tab) => {
      if (tab.dataset.target === targetId) {
        tab.classList.add("border-b-4", "border-orange", "text-orange");
        tab.classList.remove("text-gray-400");
      } else {
        tab.classList.remove("border-b-4", "border-orange", "text-orange");
        tab.classList.add("text-gray-400");
      }
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      activateTab(tab.dataset.target);
    });
  });
</script>