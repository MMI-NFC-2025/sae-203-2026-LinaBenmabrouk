---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Logo from "../assets/icons/logofooter-orange.svg";
import Vagues from "../assets/icons/vagues.svg";
import IconMail from "../assets/icons/mail.svg";
import IconMap from "../assets/icons/location.svg";
import IconPhone from "../assets/icons/call.svg";
import IconInstagram from "../assets/icons/instagram.svg";
import IconFacebook from "../assets/icons/facebook.svg";
---

<Layout title="Contact">
  <section class="pb-20 pt-16 text-center lg:pb-28">

    <div class="bg-orange pt-6 lg:pt-10">
      <Image
        src={Vagues}
        alt=""
        class="block w-full"
      />
    </div>

    <h1 class="-mt-px bg-beige text-3xl font-bold text-orange lg:text-6xl lg:pb-2">
      Contact
    </h1>

    <div class="mt-5 flex items-center justify-center gap-3 text-sm font-bold lg:mt-6 lg:gap-4">
      <a href="/">Accueil</a>
      <span class="text-orange">›</span>
      <span class="text-orange">Contact</span>
    </div>

    <div class="mt-5 flex justify-center lg:mt-8">
      <Image
        src={Logo}
        alt=""
        class="h-52 w-auto lg:h-64"
      />
    </div>

    <div class="text-center lg:mx-auto lg:max-w-4xl lg:px-10">
      <p class="px-15 text-xl leading-relaxed lg:px-0 lg:text-2xl">
        Une question, une demande ou besoin d’informations ? Notre équipe vous répond au plus vite.
      </p>
    </div>

    <div class="mt-10 px-5 lg:mt-16 lg:px-10">
      <div class="mx-auto mt-10 max-w-3xl p-8 text-left lg:mt-0 lg:max-w-6xl lg:rounded-3xl lg:bg-beige/30 lg:p-10">
        <form class="space-y-6 lg:space-y-8" method="POST" action="#">
          <div class="grid gap-6 md:grid-cols-2 lg:gap-8">

            <div>
              <label for="nom" class="mb-2 block text-sm font-bold uppercase text-orange lg:mb-3">
                Nom *
              </label>

              <input
                id="nom"
                name="nom"
                type="text"
                class="w-full rounded-lg bg-orange px-4 py-3 text-sm text-beige placeholder-beige outline-none lg:rounded-xl lg:px-5 lg:py-4"
                placeholder="Votre nom"
                required
              />
            </div>

            <div>
              <label for="email" class="mb-2 block text-sm font-bold uppercase text-orange lg:mb-3">
                Email *
              </label>

              <input
                id="email"
                name="email"
                type="email"
                class="w-full rounded-lg bg-orange px-4 py-3 text-sm text-beige placeholder-beige outline-none lg:rounded-xl lg:px-5 lg:py-4"
                placeholder="votre@email.com"
                required
              />
            </div>
          </div>

          <div>
            <label for="sujet" class="mb-2 block text-sm font-bold uppercase text-orange lg:mb-3">
              Sujet *
            </label>

            <select
              id="sujet"
              name="sujet"
              class="w-full rounded-lg bg-orange px-4 py-3 text-sm text-beige outline-none lg:rounded-xl lg:px-5 lg:py-4"
              required
            >
              <option value="" disabled selected>
                Choisissez un sujet
              </option>

              <option value="information">
                Demande d'information
              </option>

              <option value="billetterie">
                Question sur la billetterie
              </option>

              <option value="partenariat">
                Partenariat / presse
              </option>

              <option value="autre">
                Autre demande
              </option>
            </select>
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-bold uppercase text-orange lg:mb-3">
              Message *
            </label>

            <textarea
              id="message"
              name="message"
              rows="6"
              class="w-full rounded-lg bg-orange px-4 py-3 text-sm text-beige placeholder-beige outline-none lg:min-h-56 lg:rounded-xl lg:px-5 lg:py-4"
              placeholder="Écrivez votre message ici..."
              required
            ></textarea>
          </div>

          <div class="text-center lg:pt-2">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-orange px-8 py-3 text-sm font-bold uppercase text-white lg:px-10 lg:py-4"
            >
              Envoyer
            </button>
          </div>
        </form>
      </div>
    </div>

    <div class="mt-20 px-5 lg:mt-24 lg:px-10">

      <h2 class="text-3xl font-bold uppercase text-orange lg:text-4xl">
        Informations de contact
      </h2>

      <div class="mx-auto mt-10 max-w-xl space-y-6 text-center lg:mt-14 lg:max-w-5xl lg:grid lg:grid-cols-3 lg:gap-8 lg:space-y-0">
        <div class="flex items-center justify-center gap-4 lg:flex-col lg:gap-5">
          <Image src={IconMail} alt="" class="h-6 w-6 lg:h-8 lg:w-8" />
          <p class="text-base font-semibold lg:text-lg">
            contact@flyingtapfest.fr
          </p>
        </div>

        <div class="flex items-center justify-center gap-4 lg:flex-col lg:gap-5">
          <Image src={IconMap} alt="" class="h-6 w-6 lg:h-8 lg:w-8" />
          <p class="text-base font-semibold lg:text-lg">
            Parc du Près-la-Rose<br />
            25200 Montbéliard, France
          </p>
        </div>

        <div class="flex items-center justify-center gap-4 lg:flex-col lg:gap-5">
          <Image src={IconPhone} alt="" class="h-6 w-6 lg:h-8 lg:w-8" />
          <p class="text-base font-semibold lg:text-lg">
            +33 3 84 00 00 00
          </p>
        </div>
      </div>
    </div>

    <div class="mt-20 flex flex-col items-center text-center lg:mt-24">

      <Image
        src={Logo}
        alt="Flying Tap Fest"
        class="h-20 w-auto lg:h-28"
      />

      <h2 class="mt-15 text-3xl font-bold uppercase text-orange lg:mt-12 lg:text-4xl">
        Réseaux sociaux
      </h2>

      <div class="mt-4 flex items-center justify-center gap-10 lg:mt-6 lg:gap-12">
        <a
          href="https://www.iut-nfc.univ-fcomte.fr/b-u-t-metiers-du-multimedia-et-de-linternet/"
          target="_blank"
          rel="noopener"
        >
          <Image
            src={IconInstagram}
            alt="Instagram"
            class="h-10 w-auto lg:h-12"
          />
        </a>

        <a
          href="https://www.iut-nfc.univ-fcomte.fr/b-u-t-metiers-du-multimedia-et-de-linternet/"
          target="_blank"
          rel="noopener"
        >
          <Image
            src={IconFacebook}
            alt="Facebook"
            class="h-10 w-auto lg:h-12"
          />
        </a>
      </div>

      <p class="mt-6 text-base lg:text-lg">
        Au plaisir d’échanger avec vous.
      </p>

    </div>

  </section>
</Layout>