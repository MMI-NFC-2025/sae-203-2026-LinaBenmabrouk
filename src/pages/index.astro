---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { Image } from "astro:assets";
import Vagues from "../assets/icons/vagues.svg";
import Logo from "../assets/icons/logofooter-orange.svg";
import IconProgramme from "../assets/icons/calendrier.svg";
import IconArtiste from "../assets/icons/musique.svg";
import IconInfo from "../assets/icons/ticket.svg";
import Partenaire1 from "../assets/icons/partenaire1.svg";
import Partenaire2 from "../assets/icons/partenaire2.svg";
import Partenaire3 from "../assets/icons/partenaire3.svg";
import ArrowLeft from "../assets/icons/arrow_left.svg";
import ArrowRight from "../assets/icons/arrow_right.svg";
---

<Layout>
  <Hero></Hero>

  <section class="relative -mt-px">
    <Image
      src={Vagues}
      alt=""
      class="block w-full bg-orange"
    />

    <div class="px-14 pb-8 pt-2 -mt-px bg-beige text-center text-5xl font-bold">
      <div class="mx-auto h-5 w-5 rounded-full bg-yellow2"></div>

      <p class="mt-6 leading-none">
        6 & 7
      </p>

      <p class="mt-4 uppercase leading-none">
        Juin 2026
      </p>
    </div>

    <div class="px-14 pt-28">
      <h2 class="mx-auto max-w-sm text-center text-3xl font-bold leading-tight text-orange">
        Découvrez la force d’un pas de danse bien rythmé
      </h2>

      <p class="mx-auto mt-4 max-w-sm text-left text-xl leading-relaxed">
        En deux jours, vivez un festival mêlant claquettes, musique, ateliers et spectacles de drones lumineux.
      </p>
    </div>

    <div class="px-14 pb-20 pt-10">
      <div class="flex flex-col items-center text-center">
        <Image
          src={Logo}
          alt=""
          class="h-40 w-auto"
        />

        <h3 class="mt-4 text-2xl uppercase font-bold text-orange">
          Le festival
        </h3>

        <p class="px-12 text-sm leading-relaxed">
          Découvrez l’histoire et l’univers du festival.
        </p>

        <a
          href="/festival"
          class="mt-5 inline-flex items-center justify-center rounded-sm bg-orange px-10 py-2 text-sm font-bold uppercase text-white"
        >
          À propos
        </a>
      </div>

      <div class="mt-18 -mx-8 border-t border-orange"></div>

      <div class="flex flex-col items-center pt-15 text-center">
        <Image
          src={IconProgramme}
          alt=""
          class="h-20 w-auto"
        />

        <h3 class="mt-4 text-2xl uppercase font-bold text-orange">
          Programme
        </h3>

        <p class="px-12 text-sm leading-relaxed">
          Ateliers · Concerts · Shows lumineux.
        </p>

        <a
          href="/programme"
          class="mt-5 inline-flex items-center justify-center rounded-sm bg-orange px-10 py-2 text-sm font-bold uppercase text-white"
        >
          Voir le programme
        </a>
      </div>

      <div class="mt-18 -mx-8 border-t border-orange"></div>

      <div class="flex flex-col items-center pt-15 text-center">
        <Image
          src={IconArtiste}
          alt=""
          class="h-20 w-auto"
        />

        <h3 class="mt-4 text-2xl uppercase font-bold text-orange">
          Artistes
        </h3>

        <p class="px-12 text-sm leading-relaxed">
          Découvrez nos talents.
        </p>

        <a
          href="/artiste"
          class="mt-5 inline-flex items-center justify-center rounded-sm bg-orange px-10 py-2 text-sm font-bold uppercase text-white"
        >
          Voir les artistes
        </a>
      </div>

      <div class="mt-18 -mx-8 border-t border-orange"></div>

      <div class="flex flex-col items-center pt-15 text-center">
        <Image
          src={IconInfo}
          alt=""
          class="h-20 w-auto"
        />

        <h3 class="mt-4 text-2xl uppercase font-bold text-orange">
          Infos pratiques
        </h3>

        <p class="px-12 text-sm leading-relaxed">
          Accès & infos.
        </p>

        <a
          href="/infos"
          class="mt-5 inline-flex items-center justify-center rounded-sm bg-orange px-10 py-2 text-sm font-bold uppercase text-white"
        >
          En savoir plus
        </a>
      </div>

      <div class="mt-18 -mx-8 border-t border-orange"></div>

      <div class="px-8 pb-5 pt-15 text-center">
  <h3 class="text-3xl font-bold uppercase text-orange">
    Nos partenaires
  </h3>

  <p class=" text-xl leading-relaxed">
    Ils soutiennent le festival.
  </p>

  <div class="mt-14 flex items-center justify-between">
    <button
      id="partner-prev"
      class=""
      aria-label="Partenaire précédent"
    >
      <Image src={ArrowLeft} alt="" class="h-10 w-auto" />
    </button>

    <div class="flex justify-center">
      <Image
        id="partner-image"
        src={Partenaire1}
        alt="Partenaire"
        class="transition-opacity duration-300"
      />
    </div>

    <button
      id="partner-next"
      class=""
      aria-label="Partenaire suivant"
    >
      <Image src={ArrowRight} alt="" class="h-10 w-auto" />
    </button>
  </div>
</div>

    </div>
  </section>
</Layout>

<script src="../js/carousel.js"></script>