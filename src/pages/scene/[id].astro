---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import Logo from "../../assets/icons/logofooter-orange.svg";
import Vagues from "../../assets/icons/vagues.svg";
import ArrowLeft from "../../assets/icons/arrow_left.svg";
import PbImage from "../../components/PbImage.astro";
import ArtisteCard from "../../components/ArtisteCard.astro";
import { getSceneById, getArtistesBySceneId } from "../../../backend/backend.mjs";

const { id } = Astro.params;

const scene = await getSceneById(id);
const artistes: any[] = await getArtistesBySceneId(id);
---

<Layout title={scene.nom}>
  <section class="pb-20 pt-16 text-center lg:pb-28">

    <div class="bg-orange pt-6 lg:pt-10">
      <Image
        src={Vagues}
        alt=""
        class="block w-full"
      />
    </div>

    <div class="bg-beige px-5 py-2 lg:px-10">
      <div class="mx-auto flex max-w-6xl items-center justify-center gap-3 lg:gap-6">
        <button
          type="button"
          onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href = '/scene'; }"
          class="flex shrink-0 items-center justify-center rounded-full bg-orange p-2 lg:p-3"
          aria-label="Retour"
        >
          <Image
            src={ArrowLeft}
            alt=""
            class="h-4 w-4 lg:h-5 lg:w-5"
          />
        </button>

        <h1 class="text-3xl font-bold text-orange lg:text-6xl lg:pb-2">
          {scene.nom}
        </h1>
      </div>
    </div>

    <div class="mt-5 flex items-center justify-center gap-3 text-sm font-bold lg:mt-6 lg:gap-4">
      <a href="/">Accueil</a>
      <span class="text-orange">›</span>
      <a href="/scene">Scènes</a>
      <span class="text-orange">›</span>
      <span class="text-orange">{scene.nom}</span>
    </div>

    <div class="mt-5 flex justify-center lg:mt-8">
      <Image
        src={Logo}
        alt=""
        class="h-52 w-auto lg:h-64"
      />
    </div>

    <div class="mt-10 px-5 lg:px-10">
      <div class="mx-auto max-w-3xl lg:max-w-6xl">
        <div class="lg:flex lg:items-start lg:gap-10">
          <div class="overflow-hidden rounded-3xl lg:w-1/2">
            <PbImage
              record={scene}
              imageField={scene.photo}
              class="h-80 w-full object-cover lg:h-96"
            />
          </div>

          <div class="lg:w-1/2">
            <p class="mt-8 text-left text-xl leading-relaxed text-blue lg:mt-0 lg:text-lg">
              {scene.description}
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-20 px-5">
      <h2 class="text-3xl font-bold uppercase text-orange">
        Liste des artistes
      </h2>

      <div class="mt-12 space-y-12 lg:mx-auto lg:grid lg:max-w-7xl lg:grid-cols-3 lg:gap-10 lg:space-y-0">
        {artistes.map((artiste: any) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>
    </div>


    <div class="mt-12 text-center lg:mt-20 lg:px-10">
      <div class="flex justify-center">
        <Image
          src={Logo}
          alt="Flying Tap Fest"
          class="h-auto w-auto lg:h-56"
        />
      </div>

      <p class="mt-6 px-10 text-3xl font-bold uppercase text-orange lg:mx-auto lg:max-w-3xl lg:text-4xl">
        Tout ce qu'il faut savoir pour venir.
      </p>

      <a
        href="/infos"
        class="mt-6 inline-flex items-center justify-center rounded-lg bg-orange px-8 py-2 text-lg font-bold uppercase text-white lg:mt-8 lg:px-10 lg:py-3"
      >
        Voir les infos
      </a>

    </div>

  </section>
</Layout>